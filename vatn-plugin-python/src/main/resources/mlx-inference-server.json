{
  "_description": "MLX inference server — OpenAI-compatible LLM API on Apple Silicon via mlx-lm.",
  "_note": "Requires macOS on Apple Silicon (M1/M2/M3/M4). Copy to .vatn/python/apps/<name>/ and run via vatn-plugin-python.",
  "_model_examples": [
    "mlx-community/Mistral-7B-Instruct-v0.3-4bit",
    "mlx-community/Qwen2.5-14B-Instruct-4bit",
    "mlx-community/Llama-3.2-3B-Instruct-4bit",
    "mlx-community/gemma-3-4b-it-4bit"
  ],

  "run": [
    {
      "method": "fs.write",
      "params": {
        "path": "config.json",
        "data": {
          "model": "mlx-community/Mistral-7B-Instruct-v0.3-4bit",
          "port": 8080,
          "host": "127.0.0.1",
          "max_tokens": 4096
        }
      }
    },
    {
      "method": "fs.read",
      "params": { "path": "config.json" },
      "id": "cfg"
    },
    {
      "method": "shell.run",
      "params": {
        "message": "uv pip install 'mlx-lm[server]>=0.21' huggingface_hub",
        "venv": "mlx",
        "env": { "HF_HUB_ENABLE_HF_TRANSFER": "1" }
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "python -m mlx_lm.server --model mlx-community/Mistral-7B-Instruct-v0.3-4bit --host 127.0.0.1 --port 8080",
        "venv": "mlx",
        "daemon": true,
        "autoRestart": true,
        "env": {
          "TOKENIZERS_PARALLELISM": "false",
          "MLX_USE_DEFAULT_DEVICE": "gpu"
        }
      }
    }
  ]
}
